# GitHub Trending 短视频文案生成器 - 环境变量配置
# 复制此文件为 .env 并填入你的密钥

# ────────── 通用配置（默认指向 DeepSeek）──────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ────────── 各平台密钥（按需配置）──────────
# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_key_here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# ────────── TTS 语音合成 ──────────
# Edge TTS（免费，默认）无需配置

# Fish Speech（s2.cpp 本地部署，开源免费，支持声音克隆）
# 部署步骤：
#   1. git clone --recurse-submodules https://github.com/rodrigomatta/s2.cpp.git
#   2. cd s2.cpp && cmake -B build && cmake --build build --config Release --parallel
#   3. 从 https://huggingface.co/rodrigomt/s2-pro-gguf 下载模型和 tokenizer.json
#   4. .\build\Release\s2.exe --model s2-pro-q4_k_m.gguf --tokenizer tokenizer.json --server
FISH_SPEECH_SERVER=http://127.0.0.1:3030
# 声音克隆（可选）：录制 10-30 秒自己说话的音频
# FISH_REFERENCE_AUDIO=./my_voice.wav
# FISH_REFERENCE_TEXT=参考音频中说的话
